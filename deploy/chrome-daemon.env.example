# AI-hub chrome-daemon EnvironmentFile — copy alongside the systemd unit
# (chrome-daemon/install/chrome-daemon.service) on the LXC, `chmod 600`, fill in.
# NEVER commit the filled file.

# Shared secret — MUST match the Gateway's AIHUB_DAEMON_TOKEN exactly. The daemon
# is fail-closed: unset/empty → every endpoint returns 503. Generate once with
# `openssl rand -hex 32` and put the same value in the Gateway env.
AIHUB_DAEMON_TOKEN=CHANGE_ME_SHARED_TOKEN

# Extra Host headers accepted besides localhost (004-03). The nginx bundle
# overrides Host: localhost, so this can usually stay EMPTY. Only set it if a
# proxy forwards its own Host (comma-separated, e.g. "api-hub.vm").
AIHUB_ALLOWED_HOSTS=

# Chrome runs against a real X display for the ChatGPT web session.
DISPLAY=:99
